# ============================================================
#  Backend environment variables — copy this file to `.env`
#  and fill in your real values. NEVER commit the real `.env`
#  file to git (it's already in .gitignore).
# ============================================================

PORT=5001
NODE_ENV=development

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers)
MONGODB_URI=mongodb://dhwanitwork02_db_user:Dhwanit161104@ac-bq27da6-shard-00-00.5neelng.mongodb.net:27017,ac-bq27da6-shard-00-01.5neelng.mongodb.net:27017,ac-bq27da6-shard-00-02.5neelng.mongodb.net:27017/cca_admin?ssl=true&replicaSet=atlas-cnfize-shard-0&authSource=admin&retryWrites=true&w=majority

# JWT signing secret — use a long, random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=cca_super_secret_jwt_key_2026_calcricket_academy
JWT_EXPIRES_IN=7d

# Created automatically on first seed/boot if no super admin exists yet.
# If you don't set SUPER_ADMIN_PASSWORD, the seed script generates a
# random one and prints it once — write it down immediately.
SUPER_ADMIN_USERNAME=superadminwork.01
SUPER_ADMIN_PASSWORD=ccadmin@super.work.01
SUPER_ADMIN_EMAIL=superadmin@calcricket.org

# The merged frontend app runs on one origin — set both to that same URL
# in production (e.g. https://app.yourdomain.com). For local development
# the Vite dev server default is used below.
FRONTEND_URL=http://localhost:5173
HOME_FRONTEND_URL=http://localhost:5173

