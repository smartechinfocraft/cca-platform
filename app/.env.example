# Copy this file to `.env` (same folder) and fill in real values.
# Never commit the real `.env` file — it's already in .gitignore.

# Must match your backend's PORT (see backend/.env.example) + /api
VITE_API_BASE_URL=http://localhost:5001/api

# Get this from https://developer.paypal.com/dashboard/applications
# (the CLIENT ID, not the secret — the secret stays backend-only)
VITE_PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id

# Get this from Stripe Dashboard > Developers > API keys
# (the publishable key, not the secret; the secret stays backend-only)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
