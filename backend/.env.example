# ============================================================
#  Backend environment variables — copy this file to `.env`
#  and fill in your real values. NEVER commit the real `.env`
#  file to git (it's already in .gitignore).
# ============================================================

PORT=5001
NODE_ENV=development

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cca

# JWT signing secret — use a long, random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# Created automatically on first seed/boot if no super admin exists yet.
# If you don't set SUPER_ADMIN_PASSWORD, the seed script generates a
# random one and prints it once — write it down immediately.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# The merged frontend app runs on one origin — set both to that same URL
# in production (e.g. https://app.yourdomain.com). For local development
# the Vite dev server default is used below.
FRONTEND_URL=http://localhost:5173
HOME_FRONTEND_URL=http://localhost:5173

# PayPal — get these from https://developer.paypal.com/dashboard/applications
# Use PAYPAL_MODE=sandbox while testing, PAYPAL_MODE=live for real payments.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# SMTP — for sending registration confirmation / coach welcome / message
# notification emails. If using Gmail, you need an "App Password", not
# your regular password: https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=CCA <your_email@gmail.com>

# Groq — powers the "CCA Assistant" chatbot. Get a free key at
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
