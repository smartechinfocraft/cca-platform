PORT=5001
NODE_ENV=development

MONGODB_URI=your_mongodb_connection_string

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=30d

SUPER_ADMIN_USERNAME=your_admin_username
SUPER_ADMIN_PASSWORD=your_admin_password
SUPER_ADMIN_EMAIL=your_admin_email

FRONTEND_URL=http://localhost:5173
HOME_FRONTEND_URL=http://localhost:5173

# Optional. In production, point this at a persistent disk mount so uploaded
# logos/media survive rebuilds, for example /var/data/uploads on Render.
UPLOAD_DIR=

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
# From the Stripe Dashboard (or `stripe listen` CLI output in test mode) —
# required to verify that webhook calls really came from Stripe.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=your_email@example.com

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
