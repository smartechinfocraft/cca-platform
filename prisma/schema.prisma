generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COACH
  PARENT
}

model User {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  role        UserRole @default(PARENT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
